generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model admin {
  id         Int       @id @default(autoincrement())
  created_at DateTime? @default(now()) @db.Timestamp(0)
  email      String    @unique @db.VarChar(150)
  name       String    @db.VarChar(100)
  password   String    @db.VarChar(255)
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model admin_backup {
  id         Int
  name       String    @db.VarChar(100)
  email      String    @db.VarChar(150)
  password   String    @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(0)

  @@ignore
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model asia {
  id           Int      @id
  country_name String?  @db.VarChar(255)
  images       String?  @db.LongText
  is_visible   Boolean? @default(true)
}

model asiastate {
  id          Int     @id
  state_name  String  @db.VarChar(255)
  state_image String? @db.VarChar(255)
  asia_id     Int?
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model blog {
  id         Int      @id
  title      String   @db.VarChar(255)
  image      String?  @db.VarChar(500)
  date       DateTime @db.Date
  paragraphs String?  @db.LongText
}

model business_contacts {
  id             Int       @id @default(autoincrement())
  full_name      String    @db.VarChar(255)
  company_name   String    @db.VarChar(255)
  business_type  String    @db.VarChar(255)
  email          String    @db.VarChar(255)
  country_code   String?   @default("+91") @db.VarChar(10)
  phone          String    @db.VarChar(20)
  website_links  String?   @db.VarChar(500)
  office_address String?   @db.VarChar(255)
  city           String?   @db.VarChar(100)
  country        String?   @db.VarChar(100)
  created_at     DateTime? @default(now()) @db.Timestamp(0)
}

model categoryindia {
  id          Int     @id
  region_name String  @db.VarChar(100)
  image       String? @db.VarChar(255)
}

model contact {
  id                   Int       @id
  full_name            String    @db.VarChar(100)
  email                String    @db.VarChar(100)
  phone                String    @db.VarChar(20)
  country_code         String    @default("+91") @db.VarChar(10)
  contact_via_email    Boolean?  @default(false)
  contact_via_phone    Boolean?  @default(false)
  contact_via_whatsapp Boolean?  @default(false)
  created_at           DateTime? @default(now()) @db.Timestamp(0)
}

model countrytours {
  id                      Int     @id
  asiastate_id            Int
  title                   String  @db.VarChar(255)
  description             String? @db.LongText
  routing                 String? @db.LongText
  sightseeing_points      String? @db.LongText
  inclusions              String? @db.LongText
  activities              String? @db.LongText
  monument_info           String? @db.LongText
  market_info             String? @db.LongText
  supplemental_activities String? @db.LongText
  exclusions              String? @db.LongText

  @@index([asiastate_id], map: "fk_countrytours_asiastate")
}

model countrytours_faq {
  id         Int       @id
  tour_id    Int
  question   String    @db.VarChar(255)
  answer     String    @db.Text
  created_at DateTime? @default(now()) @db.Timestamp(0)
  updated_at DateTime? @default(now()) @db.Timestamp(0)

  @@index([tour_id], map: "tour_id")
}

model doc {
  id          Int       @id
  user_id     Int
  pdf_name    String    @db.VarChar(255)
  pdf_file    Bytes?
  pdf_text    String?   @db.LongText
  uploaded_at DateTime? @default(now()) @db.Timestamp(0)
}

model enquiries {
  id             Int       @id @default(autoincrement())
  user_id        Int?
  name           String    @db.VarChar(100)
  email          String    @db.VarChar(100)
  phone          String    @db.VarChar(20)
  origin         String    @db.VarChar(150)
  destination    String    @db.VarChar(150)
  arrival_date   DateTime  @db.Date
  departure_date DateTime  @db.Date
  hotel_category String?   @db.VarChar(100)
  no_of_adults   Int       @default(1)
  no_of_children Int?      @default(0)
  message        String?   @db.Text
  created_at     DateTime? @default(now()) @db.Timestamp(0)

  @@index([user_id], map: "fk_user")
}

model feedback {
  id          Int              @id @default(autoincrement())
  name        String           @db.VarChar(100)
  photo       String?          @db.VarChar(255)
  origin      String?          @db.VarChar(100)
  destination String?          @db.VarChar(255)
  rating      Int              @db.TinyInt
  review      String           @db.Text
  created_at  DateTime?        @default(now()) @db.Timestamp(0)
  status      feedback_status? @default(pending)
}

model orders {
  id         Int       @id @default(autoincrement())
  order_id   String    @db.VarChar(255)
  payment_id String?   @db.VarChar(255)
  amount     Decimal   @db.Decimal(10, 2)
  currency   String?   @default("INR") @db.VarChar(10)
  status     String?   @default("created") @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamp(0)
}

model payments {
  id            Int       @id @default(autoincrement())
  name          String?   @db.VarChar(255)
  email         String?   @db.VarChar(255)
  phone         String?   @db.VarChar(50)
  transactionId String?   @db.VarChar(255)
  screenshot    String?   @db.VarChar(255)
  time          DateTime? @db.DateTime(0)
  currency      String?   @default("INR") @db.VarChar(5)
}

model state {
  id          Int      @id @default(autoincrement())
  state_name  String   @db.VarChar(100)
  image       String?  @db.VarChar(500)
  category_id Int?
  is_visible  Boolean? @default(true)

  @@index([category_id], map: "category_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model tours {
  id                      Int       @id @default(autoincrement())
  state_id                Int
  title                   String    @db.VarChar(255)
  description             String?   @db.Text
  created_at              DateTime? @default(now()) @db.Timestamp(0)
  updated_at              DateTime? @default(now()) @db.Timestamp(0)
  routing                 String?   @db.LongText
  sightseeing_points      String?   @db.LongText
  inclusions              String?   @db.LongText
  activities              String?   @db.LongText
  monument_info           String?   @db.LongText
  market_info             String?   @db.LongText
  supplemental_activities String?   @db.LongText
  exclusions              String?   @db.LongText

  @@index([state_id], map: "state_id")
}

model tours_faq {
  id         Int       @id
  question   String    @db.VarChar(255)
  answer     String    @db.Text
  created_at DateTime? @default(now()) @db.Timestamp(0)
  updated_at DateTime? @default(now()) @db.Timestamp(0)
  state_id   Int?
  tour_id    Int?

  @@index([state_id], map: "state_id")
  @@index([tour_id], map: "tour_id")
}

model user_documents {
  id          Int       @id @default(autoincrement())
  user_id     Int
  pdf_name    String?   @db.VarChar(255)
  pdf_file    Bytes?
  uploaded_at DateTime? @default(now()) @db.Timestamp(0)
}

model userdocuments {
  id          Int       @id @default(autoincrement())
  user_id     Int
  pdf_name    String    @db.VarChar(255)
  pdf_file    Bytes
  pdf_text    String?   @db.Text
  uploaded_at DateTime? @default(now()) @db.Timestamp(0)

  @@index([user_id], map: "user_id")
}

model userregister {
  id                 Int       @id @default(autoincrement())
  name               String    @db.VarChar(100)
  email              String    @unique(map: "email") @db.VarChar(150)
  mobile             String    @db.VarChar(15)
  password           String    @db.VarChar(255)
  country            String    @db.VarChar(100)
  admin_message      String?   @db.Text
  created_at         DateTime? @default(now()) @db.Timestamp(0)
  reset_token        String?   @db.VarChar(255)
  reset_token_expire DateTime? @db.DateTime(0)
  admin_document     String?   @db.VarChar(255)
  pdf_file           Bytes?
  admin_pdf          Bytes?
  admin_pdf_name     String?   @db.VarChar(255)
}

model landing_page {
  id        Int      @id @default(autoincrement())
  slug      String   @unique @db.VarChar(100)
  title     String   @db.VarChar(255)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model settings {
  id             Int      @id @default(1)
  primaryColor   String   @default("#f97316")
  secondaryColor String   @default("#fbbf24")
  fontFamily     String   @default("Poppins")
  navbarColor    String   @default("#ffffff")
  footerColor    String   @default("#0f172a")
  glassEffect    Boolean @default(false)
  borderRadius   Int     @default(12)
  cardHoverStyle String  @default("parallax")
  primaryGradient String @default("linear-gradient(135deg, #f97316 0%, #fbbf24 100%)")
  darkTheme      Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum feedback_status {
  pending
  approved
  rejected
}

model upcoming_trips {
  id           Int       @id @default(autoincrement())
  title        String    @db.VarChar(255)
  images       String?   @db.LongText
  banner_image String?   @db.VarChar(500)
  description  String?   @db.LongText
  details      Json?
  tags         String?   @db.VarChar(500)
  link         String?   @db.VarChar(500)
  is_visible   Boolean?  @default(true)
  created_at   DateTime? @default(now()) @db.Timestamp(0)
}
